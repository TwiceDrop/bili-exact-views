{
  "manifest_version": 3,
  "name": "B站精确播放量",
  "version": "1.2.4",
  "description": "在 B 站视频详情页显示播放、弹幕、点赞、投币、收藏和分享的精确数量。",
  "permissions": [],
  "host_permissions": [
    "https://api.bilibili.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.bilibili.com/video/*"
      ],
      "js": [
        "lib.js",
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
